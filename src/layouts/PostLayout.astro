---
import BaseLayout from "./BaseLayout.astro";
import { postUrl, type Post } from "../lib/posts";
import { SITE, type SeriesMeta } from "../config";

interface SeriesContext {
  slug: string;
  meta: SeriesMeta;
  index: number;
  total: number;
  prev: Post | null;
  next: Post | null;
}

interface Props {
  title: string;
  description?: string;
  date: Date;
  updated?: Date;
  tags?: string[];
  repo?: string;
  series?: SeriesContext | null;
}

const { title, description, date, updated, tags = [], repo, series } =
  Astro.props;
const repoLabel = repo
  ? repo.replace(/^https?:\/\/github\.com\//, "").replace(/\/$/, "")
  : "";
const githubIcon = `<svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`;
const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const blogPostingLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  ...(description ? { description } : {}),
  datePublished: date.toISOString(),
  dateModified: (updated ?? date).toISOString(),
  author: { "@type": "Person", name: SITE.author, url: SITE.url },
  publisher: { "@type": "Person", name: SITE.author, url: SITE.url },
  mainEntityOfPage: canonical,
  image: new URL("/og.png", Astro.site).toString(),
  ...(tags.length ? { keywords: tags.join(", ") } : {}),
};
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  publishedTime={date}
  modifiedTime={updated}
  tags={tags}
  jsonLd={blogPostingLd}
>
  <article>
    <header class="mb-8">
      {
        series ? (
          <a
            href={`/blog/series/${series.slug}/`}
            class="text-sm text-zinc-500 transition-colors hover:text-[var(--color-accent)] dark:text-zinc-400 dark:hover:text-[var(--color-accent-dark)]"
          >
            ← {series.meta.title}
          </a>
        ) : (
          <a
            href="/blog"
            class="text-sm text-zinc-500 transition-colors hover:text-[var(--color-accent)] dark:text-zinc-400 dark:hover:text-[var(--color-accent-dark)]"
          >
            ← Blog
          </a>
        )
      }
      <h1
        class="mt-4 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl dark:text-zinc-100"
      >
        {title}
      </h1>
      <div
        class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-zinc-500 dark:text-zinc-400"
      >
        <time datetime={date.toISOString()}>{fmt(date)}</time>
        {updated && <span>· Updated {fmt(updated)}</span>}
        {
          series && (
            <span>
              · Part {series.index + 1} of {series.total} in{" "}
              <a
                href={`/blog/series/${series.slug}/`}
                class="hover:text-[var(--color-accent)] dark:hover:text-[var(--color-accent-dark)]"
              >
                {series.meta.title}
              </a>
            </span>
          )
        }
        {
          tags.length > 0 && (
            <span class="flex flex-wrap gap-2">
              {tags.map((t) => (
                <span class="rounded bg-zinc-100 px-1.5 py-0.5 text-xs text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300">
                  {t}
                </span>
              ))}
            </span>
          )
        }
      </div>
      {
        repo && (
          <div class="mt-4">
            <a
              href={repo}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 rounded-md border border-zinc-300 px-3 py-1 text-sm font-medium text-zinc-700 transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-[var(--color-accent-dark)] dark:hover:text-[var(--color-accent-dark)]"
            >
              <span class="shrink-0" set:html={githubIcon} />
              {repoLabel}
            </a>
          </div>
        )
      }
    </header>

    <div
      class="prose prose-zinc max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-a:text-[var(--color-accent)] prose-a:no-underline [&_a:hover]:underline prose-pre:rounded-lg prose-pre:border prose-pre:border-zinc-200 dark:prose-invert dark:prose-a:text-[var(--color-accent-dark)] dark:prose-pre:border-zinc-800"
    >
      <slot />
    </div>

    {
      series && (series.prev || series.next || series.meta.next) && (
        <nav class="mt-12 grid grid-cols-2 gap-4 border-t border-zinc-200 pt-6 text-sm dark:border-zinc-800">
          <div>
            {series.prev && (
              <a
                href={postUrl(series.prev)}
                class="group block text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100"
              >
                <span class="block text-xs uppercase tracking-wider text-zinc-400 dark:text-zinc-500">
                  ← Previous
                </span>
                <span class="mt-1 block font-medium">{series.prev.data.title}</span>
              </a>
            )}
          </div>
          <div class="text-right">
            {series.next ? (
              <a
                href={postUrl(series.next)}
                class="group block text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100"
              >
                <span class="block text-xs uppercase tracking-wider text-zinc-400 dark:text-zinc-500">
                  Next →
                </span>
                <span class="mt-1 block font-medium">{series.next.data.title}</span>
              </a>
            ) : (
              series.meta.next && (
                <a
                  href={series.meta.next.href}
                  class="group block text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100"
                >
                  <span class="block text-xs uppercase tracking-wider text-zinc-400 dark:text-zinc-500">
                    Up next →
                  </span>
                  <span class="mt-1 block font-medium">{series.meta.next.title}</span>
                </a>
              )
            )}
          </div>
        </nav>
      )
    }
  </article>
</BaseLayout>
