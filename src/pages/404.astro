---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not found">
  <section class="py-16 text-center">
    <p class="text-5xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
      404
    </p>
    <p class="mt-3 text-zinc-600 dark:text-zinc-400">
      This page doesn't exist.
    </p>
    <a
      href="/"
      class="mt-6 inline-block text-sm text-[var(--color-accent)] hover:underline dark:text-[var(--color-accent-dark)]"
    >
      ← Back home
    </a>
  </section>
</BaseLayout>
