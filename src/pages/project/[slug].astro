---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SITE } from "../../config";
import { PROJECTS } from "../../data/projects";

export function getStaticPaths() {
  return PROJECTS.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const date = new Date(project.date);
const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const codeRepo = project.links.find((l) => l.label === "Code")?.href;
const projectLd = {
  "@context": "https://schema.org",
  "@type": codeRepo ? "SoftwareSourceCode" : "CreativeWork",
  name: project.title,
  description: project.description,
  url: canonical,
  datePublished: date.toISOString(),
  author: { "@type": "Person", name: SITE.author, url: SITE.url },
  keywords: project.tags.join(", "),
  ...(project.image
    ? { image: new URL(project.image, Astro.site).toString() }
    : {}),
  ...(codeRepo ? { codeRepository: codeRepo } : {}),
};

// Monochrome icons (inherit currentColor) keyed by link label.
const linkIcons: Record<string, string> = {
  Code: `<svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
  PDF: `<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>`,
  Slides: `<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h20"/><path d="M21 3v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V3"/><path d="m7 21 5-5 5 5"/></svg>`,
};
---

<BaseLayout
  title={project.title}
  description={project.description}
  image={project.image}
  jsonLd={projectLd}
>
  <article>
    <header class="mb-6">
      <a
        href="/projects"
        class="text-sm text-zinc-500 transition-colors hover:text-[var(--color-accent)] dark:text-zinc-400 dark:hover:text-[var(--color-accent-dark)]"
      >
        ← Projects
      </a>
      <h1
        class="mt-4 text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl dark:text-zinc-100"
      >
        {project.title}
      </h1>
      <div
        class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-zinc-500 dark:text-zinc-400"
      >
        <time datetime={date.toISOString()}>{fmt(date)}</time>
        <span>
          · {project.venue ?? `${project.level} Course Project, ${project.school}`}
        </span>
        {
          project.tags.length > 0 && (
            <span class="flex flex-wrap gap-2">
              {project.tags.map((t) => (
                <span class="rounded bg-zinc-100 px-1.5 py-0.5 text-xs text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300">
                  {t}
                </span>
              ))}
            </span>
          )
        }
      </div>
      {
        project.award && (
          <div class="mt-3">
            <a
              href={project.award.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 rounded-full border border-amber-400/60 bg-amber-50 px-3 py-1 text-sm font-medium text-amber-700 transition-colors hover:bg-amber-100 dark:border-amber-500/40 dark:bg-amber-500/10 dark:text-amber-300 dark:hover:bg-amber-500/20"
            >
              🏆 {project.award.label}
            </a>
          </div>
        )
      }

      <p class="mt-4 text-lg leading-relaxed text-zinc-600 dark:text-zinc-400">
        {project.description}
      </p>

      {
        project.links.length > 0 && (
          <div class="mt-5 flex flex-wrap gap-2">
            {project.links.map((l) => (
              <a
                href={l.href}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 rounded-md border border-zinc-300 px-3 py-1 text-sm font-medium text-zinc-700 transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-[var(--color-accent-dark)] dark:hover:text-[var(--color-accent-dark)]"
              >
                {linkIcons[l.label] && (
                  <span class="shrink-0" set:html={linkIcons[l.label]} />
                )}
                {l.label}
              </a>
            ))}
          </div>
        )
      }
    </header>

    {
      project.image && (
        <div class="mb-8 flex justify-center rounded-lg border border-zinc-200 bg-zinc-50 p-4 dark:border-zinc-800 dark:bg-zinc-900/50">
          <img
            src={project.image}
            alt={project.title}
            class="max-h-80 w-auto rounded object-contain"
          />
        </div>
      )
    }

    <div
      class="prose prose-zinc max-w-none prose-a:text-[var(--color-accent)] prose-a:no-underline [&_a:hover]:underline dark:prose-invert dark:prose-a:text-[var(--color-accent-dark)]"
    >
      {project.body.map((p) => <p>{p}</p>)}
    </div>
  </article>
</BaseLayout>
